{
  "name": "@pedrolamas/plugin-vue2",
  "version": "2.3.4",
  "license": "MIT",
  "author": "Pedro Lamas",
  "packageManager": "pnpm@10.24.0",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "unbuild --stub",
    "build": "unbuild && esno scripts/patchCJS.ts",
    "test": "vitest run",
    "release": "node scripts/release.js",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedrolamas/vite-plugin-vue2.git",
    "directory": "packages/plugin-vue"
  },
  "bugs": {
    "url": "https://github.com/pedrolamas/vite-plugin-vue2/issues"
  },
  "homepage": "https://github.com/pedrolamas/vite-plugin-vue2/#readme",
  "peerDependencies": {
    "vite": "^8.0.0",
    "vue": "^2.7.0-0"
  },
  "devDependencies": {
    "@types/fs-extra": "^9.0.13",
    "conventional-changelog-cli": "^2.2.2",
    "debug": "^4.4.3",
    "enquirer": "^2.4.1",
    "esno": "^4.8.0",
    "execa": "^4.1.0",
    "fs-extra": "^10.1.0",
    "hash-sum": "^2.0.0",
    "minimist": "^1.2.8",
    "picocolors": "^1.1.1",
    "prettier": "^2.8.8",
    "puppeteer": "^14.4.1",
    "rollup": "^2.80.0",
    "semver": "^7.7.4",
    "slash": "^3.0.0",
    "source-map": "^0.6.1",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "vite": "^8.0.0",
    "vitest": "^0.15.2",
    "vue": "^2.7.16"
  }
}
